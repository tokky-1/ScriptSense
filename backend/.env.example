# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-this-to-a-secure-secret-key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── Model paths ───────────────────────────────────────────────────────────────
MODEL_PATH=../model/saved_models
YOLO_MODEL_PATH=../model/saved_models/line_detector_best.pt
TROCR_MODEL_NAME=microsoft/trocr-large-handwritten
TROCR_MODEL_NAME=../model/saved_models/trocr

# ── External API keys ─────────────────────────────────────────────────────────
OLLAMA_API_KEY=

# ── Upload constraints ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MAX_IMAGES_PER_REQUEST=30

# ── Temp directory ────────────────────────────────────────────────────────────
TEMP_DIR=/tmp/scriptsense
